---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
---

<Layout title="About">
  <Container>
    <Sectionhead>
      <Fragment slot="title">About</Fragment>
      <Fragment slot="desc">Expert IT consulting for modern enterprises.</Fragment>
    </Sectionhead>

    <div class="flex flex-col gap-3 mx-auto max-w-4xl mt-16">
      <h2 class="font-bold text-3xl text-gray-800">
        Transforming Business Through Technology
      </h2>
      <p class="text-lg leading-relaxed text-slate-500">
        Kynowa is a Melbourne-based IT consulting firm specializing in cloud solutions, cybersecurity, and IT infrastructure. We partner with businesses to design, implement, and secure their technology ecosystems, enabling growth and innovation in an increasingly digital world.
      </p>
      <p class="text-lg leading-relaxed text-slate-500">
        Our expertise spans cloud migrations, security assessments, infrastructure optimization, and strategic IT planning. We're committed to delivering tailored solutions that align with your business objectives.
      </p>
    </div>
  </Container>
</Layout>
